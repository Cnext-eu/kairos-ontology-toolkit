@prefix acme:    <https://acme.example/ontology/client#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix fibo-id: <https://spec.edmcouncil.org/fibo/ontology/FND/Arrangements/Identifiers/> .
@prefix fibo-pt: <https://spec.edmcouncil.org/fibo/ontology/FND/Parties/Parties/> .

# ---------------------------------------------------------------------------
# Client → FIBO Alignment
# Reference Model Inspired: NOT loaded during projections.
# ---------------------------------------------------------------------------
<https://acme.example/ontology/client/alignment/fibo> a owl:Ontology ;
    rdfs:label "Client → FIBO Alignment"@en ;
    rdfs:comment "Standards correspondence for the Acme client domain. This file is NEVER loaded by projectors — it exists for semantic interoperability documentation only."@en ;
    owl:versionInfo "1.0.0" .

# Class alignments
acme:Client       skos:closeMatch  fibo-pt:PartyInRole .
acme:Identifier   skos:exactMatch  fibo-id:Identifier .

# Property alignments
acme:identifierValue     skos:exactMatch  fibo-id:hasTag .
acme:identifierScheme    skos:closeMatch  fibo-id:isDefinedIn .
acme:identifierValidFrom skos:closeMatch  fibo-id:hasApplicablePeriod .
acme:isIdentifiedBy      skos:exactMatch  fibo-id:isIdentifiedBy .

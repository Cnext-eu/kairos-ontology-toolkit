@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix refp: <https://refmodel.example/ontology/party#> .

# ---------------------------------------------------------------------------
# Reference model — simulates an external party ontology (BSP-like)
# Used by the "logistics" domain via owl:imports for DD-021 testing.
# Prefixed with _ to exclude from domain ontology discovery.
# ---------------------------------------------------------------------------
<https://refmodel.example/ontology/party> a owl:Ontology ;
    rdfs:label "Reference Party Model" ;
    owl:versionInfo "1.0.0" ;
    rdfs:comment "External reference model for scenario testing (DD-021)." .

refp:TradeParty a owl:Class ;
    rdfs:label "Trade Party" ;
    rdfs:comment "A party involved in trade transactions." .

refp:Carrier a owl:Class ;
    rdfs:label "Carrier" ;
    rdfs:comment "A transport carrier." .

refp:partyCode a owl:DatatypeProperty ;
    rdfs:label "party code" ;
    rdfs:comment "Unique business identifier for the trade party." ;
    rdfs:domain refp:TradeParty ;
    rdfs:range xsd:string .

refp:partyName a owl:DatatypeProperty ;
    rdfs:label "party name" ;
    rdfs:comment "Display name of the trade party." ;
    rdfs:domain refp:TradeParty ;
    rdfs:range xsd:string .

refp:carrierCode a owl:DatatypeProperty ;
    rdfs:label "carrier code" ;
    rdfs:comment "SCAC or similar carrier identification code." ;
    rdfs:domain refp:Carrier ;
    rdfs:range xsd:string .

refp:Address a owl:Class ;
    rdfs:label "Address" ;
    rdfs:comment "A postal or physical address — NOT claimed by any silver extension." .

refp:addressLine a owl:DatatypeProperty ;
    rdfs:label "address line" ;
    rdfs:comment "Free-text address line." ;
    rdfs:domain refp:Address ;
    rdfs:range xsd:string .

# ---------------------------------------------------------------------------
# Issue #172 (B) — transitive discriminator fold fixture.
# Organization is a claimed discriminator root; ShipOperator is an UNCLAIMED
# intermediate; a local subtype (acme-log:VesselCarrier) reaches the
# discriminator root only through the unclaimed intermediate and must still fold.
# ---------------------------------------------------------------------------
refp:Organization a owl:Class ;
    rdfs:label "Organization" ;
    rdfs:comment "A legal organization — claimed discriminator root for #172." .

refp:orgName a owl:DatatypeProperty ;
    rdfs:label "org name" ;
    rdfs:comment "Registered organization name." ;
    rdfs:domain refp:Organization ;
    rdfs:range xsd:string .

refp:ShipOperator a owl:Class ;
    rdfs:subClassOf refp:Organization ;
    rdfs:label "Ship Operator" ;
    rdfs:comment "Operates vessels — UNCLAIMED intermediate for #172." .

refp:shipOperatorCode a owl:DatatypeProperty ;
    rdfs:label "ship operator code" ;
    rdfs:comment "Identification code of the ship operator." ;
    rdfs:domain refp:ShipOperator ;
    rdfs:range xsd:string .

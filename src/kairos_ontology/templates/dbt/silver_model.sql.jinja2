--
-- Maps bronze source tables to the silver domain entity.
-- Column definitions align with the silver projector DDL output.
{%- if scd_type == "2" %}
-- SCD Type 2: incremental with change detection (insert new + close prior)
{%- elif scd_type == "1" %}
-- SCD Type 1: incremental upsert (overwrite in place)
{%- endif %}

{%- if unique_key is sequence and unique_key is not string %}
{{"{{"}} config(
    materialized='{{ materialization | default("table") }}',
    schema='{{ schema_name }}',
    unique_key={{ unique_key }}
) {{"}}"}}
{%- elif unique_key %}
{{"{{"}} config(
    materialized='{{ materialization | default("table") }}',
    schema='{{ schema_name }}',
    unique_key='{{ unique_key }}'
) {{"}}"}}
{%- else %}
{{"{{"}} config(
    materialized='{{ materialization | default("table") }}',
    schema='{{ schema_name }}'
) {{"}}"}}
{%- endif %}

{%- for cte in source_ctes %}

{% if loop.first %}with {% else %}     {% endif %}{{ cte.alias }} as (

{%- if cte.ref_model %}
    select * from {{"{{"}} ref('{{ cte.ref_model }}') {{"}}"}}
{%- else %}
    select * from {{"{{"}} source('{{ cte.source_name }}', '{{ cte.table_name }}') {{"}}"}}
{%- endif %}
{%- if cte.filter %}
    where {{ cte.filter }}
{%- endif %}

){% if not loop.last %},{% endif %}
{%- endfor %}
{%- if scd_type == "2" %}
{%- set mapped_cols = [] %}
{%- for col in columns %}
{%- if col.target_name != model_name + "_sk" and col.target_name != model_name + "_iri" and not col.generated_after_mapping | default(false) %}
{%- set _ = mapped_cols.append(col) %}
{%- endif %}
{%- endfor %}
,

mapped as (

    select
{%- for col in mapped_cols %}
        {{ col.expression }} as {{ col.target_name }}{% if not loop.last %},{% endif %}{% if col.comment is defined and col.comment %}  -- {{ col.comment }}{% endif %}
{%- endfor %}
    from {{ source_ctes[0].alias }}
{%- for join in joins %}
    {{ join.type }} join {{ join.ref }} as {{ join.alias }}
        on {{ join.condition }}
{%- endfor %}
{%- if where_clause %}
    where {{ where_clause }}
{%- endif %}

),

source_data as (

    select
{%- for col in columns %}
{%- if col.target_name == model_name + "_sk" or col.target_name == model_name + "_iri" or col.generated_after_mapping | default(false) %}
        {{ col.expression }} as {{ col.target_name }},
{%- else %}
        {{ col.target_name }},
{%- endif %}
{%- endfor %}
{%- if hash_columns %}
        {{"{{"}} kairos_row_hash([{% for hc in hash_columns %}'{{ hc }}'{% if not loop.last %}, {% endif %}{% endfor %}]) {{"}}"}} as _row_hash,
{%- endif %}
        {{ valid_from_expression | default("{{ kairos_current_timestamp() }}", true) }} as valid_from
    from mapped

),

source_ranked as (

    select
        *,
        LAG(_row_hash) over (
            partition by {{ model_name }}_sk order by valid_from
        ) as _previous_source_hash
    from source_data

),

source_changes as (

    select *
    from source_ranked
    where _previous_source_hash is null or _previous_source_hash != _row_hash

),

source_versions as (

    select
        *,
        LEAD(valid_from) over (
            partition by {{ model_name }}_sk order by valid_from
        ) as valid_to,
        case
            when LEAD(valid_from) over (
                partition by {{ model_name }}_sk order by valid_from
            ) is null then 1
            else 0
        end as is_current
    from source_changes

)

{{"{%"}} if is_incremental() {{"%}"}}
,

existing as (

    select {{ model_name }}_sk, _row_hash
    from {{"{{"}} this {{"}}"}}
    where is_current = 1

),

changed as (

    select s.*
    from source_versions s
    left join existing e on s.{{ model_name }}_sk = e.{{ model_name }}_sk
    where s._previous_source_hash is not null
       or e.{{ model_name }}_sk is null
       or e._row_hash != s._row_hash

),

first_changed as (

    select {{ model_name }}_sk, min(valid_from) as valid_from
    from changed
    group by {{ model_name }}_sk

),

closed as (

    select
        t.{{ model_name }}_sk,
{%- for col in columns %}
{%- if col.target_name != model_name + "_sk" %}
        t.{{ col.target_name }},
{%- endif %}
{%- endfor %}
        t._row_hash,
        t.valid_from,
        c.valid_from as valid_to,
        0 as is_current
    from {{"{{"}} this {{"}}"}} t
    inner join first_changed c on t.{{ model_name }}_sk = c.{{ model_name }}_sk
    where t.is_current = 1

)
{{"{%"}} endif {{"%}"}}

select
    {{ model_name }}_sk,
{%- for col in columns %}
{%- if col.target_name != model_name + "_sk" %}
    {{ col.target_name }},
{%- endif %}
{%- endfor %}
    _row_hash,
    valid_from,
    valid_to,
    is_current
from {{"{%"}} if is_incremental() {{"%}"}}changed{{"{%"}} else {{"%}"}}source_versions{{"{%"}} endif {{"%}"}}

{{"{%"}} if is_incremental() {{"%}"}}
union all

select
    {{ model_name }}_sk,
{%- for col in columns %}
{%- if col.target_name != model_name + "_sk" %}
    {{ col.target_name }},
{%- endif %}
{%- endfor %}
    _row_hash,
    valid_from,
    valid_to,
    is_current
from closed
{{"{%"}} endif {{"%}"}}
{%- elif source_ctes | length > 1 %}
,

final as (

    select
{%- for col in columns %}
        {{ col.expression }} as {{ col.target_name }}{% if not loop.last %},{% endif %}{% if col.comment is defined and col.comment %}  -- {{ col.comment }}{% endif %}
{%- endfor %}
    from {{ source_ctes[0].alias }}
{%- for join in joins %}
    {{ join.type }} join {{ join.ref }} as {{ join.alias }}
        on {{ join.condition }}
{%- endfor %}
{%- if where_clause %}
    where {{ where_clause }}
{%- endif %}

)

select * from final
{%- else %}

select
{%- for col in columns %}
    {{ col.expression }} as {{ col.target_name }}{% if not loop.last %},{% endif %}{% if col.comment is defined and col.comment %}  -- {{ col.comment }}{% endif %}
{%- endfor %}
from {{ source_ctes[0].alias }}
{%- for join in joins %}
    {{ join.type }} join {{ join.ref }} as {{ join.alias }}
        on {{ join.condition }}
{%- endfor %}
{%- if where_clause %}
where {{ where_clause }}
{%- endif %}
{%- endif %}

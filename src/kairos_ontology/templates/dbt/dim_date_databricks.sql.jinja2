-- dim_date: standard date dimension (Databricks / Spark SQL)
-- Generated by Kairos Ontology Toolkit (dbt projector)
-- Platform: Databricks (Spark SQL)

{{ config(
    materialized='table',
    schema='{{ schema_name }}'
) }}

with date_spine as (

    select
        DATEADD(day, ROW_NUMBER() OVER (ORDER BY NULL) - 1,
                '2000-01-01'::DATE) as date_key
    from TABLE(GENERATOR(ROWCOUNT => 36525))  -- ~100 years

)

select
    CAST(DATE_FORMAT(date_spine.date_key, 'yyyyMMdd') AS INT) as date_key_int,
    date_spine.date_key as full_date,
    YEAR(date_spine.date_key) as year,
    QUARTER(date_spine.date_key) as quarter,
    MONTH(date_spine.date_key) as month,
    DAY(date_spine.date_key) as day_of_month,
    DAYOFWEEK(date_spine.date_key) as day_of_week,
    MONTHNAME(date_spine.date_key) as month_name,
    CASE WHEN DAYOFWEEK(date_spine.date_key) IN (0, 6)
         THEN TRUE ELSE FALSE END as is_weekend
from date_spine

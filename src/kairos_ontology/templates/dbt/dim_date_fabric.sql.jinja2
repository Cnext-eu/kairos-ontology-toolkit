with date_spine as (

    select
        DATEADD(day, value, CAST('2000-01-01' AS DATE)) as date_key
    from GENERATE_SERIES(0, 36524)  -- ~100 years (2000-01-01 to 2099-12-31)

)

select
    CAST(FORMAT(date_spine.date_key, 'yyyyMMdd') AS INT) as date_key_int,
    date_spine.date_key as full_date,
    YEAR(date_spine.date_key) as year,
    DATEPART(quarter, date_spine.date_key) as quarter,
    MONTH(date_spine.date_key) as month,
    DAY(date_spine.date_key) as day_of_month,
    DATEPART(weekday, date_spine.date_key) as day_of_week,
    CAST(DATENAME(month, date_spine.date_key) AS VARCHAR(30)) as month_name,
    CASE WHEN DATEPART(weekday, date_spine.date_key) IN (1, 7)
         THEN 1 ELSE 0 END as is_weekend
from date_spine

-- Silver union model: {{ model_name }}
-- Domain: {{ domain_name }} ({{ schema_name }})
-- Generated by Kairos Ontology Toolkit (dbt projector)
{%- if ontology_metadata and ontology_metadata.generated_at %}
-- Generated at: {{ ontology_metadata.generated_at }}
{%- endif %}
{%- if ontology_metadata and ontology_metadata.iri %}
-- Ontology: {{ ontology_metadata.iri }}
{%- endif %}
{%- if ontology_metadata and ontology_metadata.version %}
-- Ontology version: {{ ontology_metadata.version }}
{%- endif %}
{%- if ontology_metadata and ontology_metadata.toolkit_version %}
-- Toolkit version: {{ ontology_metadata.toolkit_version }}
{%- endif %}
{%- if ontology_metadata and ontology_metadata.silver_default_packages %}
-- Silver defaults: {{ ontology_metadata.silver_default_packages | join(", ") }}
{%- endif %}
{%- if ontology_metadata and ontology_metadata.silver_overrides %}
-- Hub overrides: {{ ontology_metadata.silver_overrides | join(", ") }}
{%- endif %}
--
-- Combines {{ source_models | length }} per-source models via UNION ALL, then
-- computes surrogate key (SK) and IRI on normalised columns.

{%- if unique_key is sequence and unique_key is not string %}
{{"{{"}} config(
    materialized='{{ materialization }}',
    schema='{{ schema_name }}',
    unique_key={{ unique_key }}
) {{"}}"}}
{%- else %}
{{"{{"}} config(
    materialized='{{ materialization }}',
    schema='{{ schema_name }}',
    unique_key='{{ unique_key }}'
) {{"}}"}}
{%- endif %}

with unioned as (

{%- for src in source_models %}
    select
        _source_system,
        _source_record_id,
{%- for col in columns %}
        {{ col.target_name }}{% if not loop.last %},{% endif %}
{%- endfor %}
    from {{"{{"}} ref('{{ src }}') {{"}}"}}
{%- if not loop.last %}
    union all
{%- endif %}
{%- endfor %}

)
{%- if scd_type == "2" %}
,

source_data as (

    select
    {{ sk_expression }} as {{ model_name }}_sk,
    {{ iri_expression }} as {{ model_name }}_iri,
    _source_system,
    _source_record_id,
    {{"{{"}} kairos_current_timestamp() {{"}}"}} as _loaded_at,
{%- for col in columns %}
    {{ col.target_name }},
{%- endfor %}
    {{"{{"}} kairos_row_hash([{% for hc in hash_columns %}'{{ hc }}'{% if not loop.last %}, {% endif %}{% endfor %}]) {{"}}"}} as _row_hash,
    {{ valid_from_expression | default("{{ kairos_current_timestamp() }}", true) }} as valid_from
    from unioned
),

source_ranked as (
    select
        *,
        LAG(_row_hash) over (
            partition by {{ model_name }}_sk order by valid_from
        ) as _previous_source_hash
    from source_data
),

source_changes as (
    select *
    from source_ranked
    where _previous_source_hash is null or _previous_source_hash != _row_hash
),

source_versions as (
    select
        *,
        LEAD(valid_from) over (
            partition by {{ model_name }}_sk order by valid_from
        ) as valid_to,
        case
            when LEAD(valid_from) over (
                partition by {{ model_name }}_sk order by valid_from
            ) is null then 1
            else 0
        end as is_current
    from source_changes
)

{{"{%"}} if is_incremental() {{"%}"}}
,

existing as (
    select {{ model_name }}_sk, _row_hash
    from {{"{{"}} this {{"}}"}}
    where is_current = 1
),

changed as (
    select s.*
    from source_versions s
    left join existing e on s.{{ model_name }}_sk = e.{{ model_name }}_sk
    where s._previous_source_hash is not null
       or e.{{ model_name }}_sk is null
       or e._row_hash != s._row_hash
),

first_changed as (
    select {{ model_name }}_sk, min(valid_from) as valid_from
    from changed
    group by {{ model_name }}_sk
),

closed as (
    select
        t.{{ model_name }}_sk,
        t.{{ model_name }}_iri,
        t._source_system,
        t._source_record_id,
        t._loaded_at,
{%- for col in columns %}
        t.{{ col.target_name }},
{%- endfor %}
        t._row_hash,
        t.valid_from,
        c.valid_from as valid_to,
        0 as is_current
    from {{"{{"}} this {{"}}"}} t
    inner join first_changed c on t.{{ model_name }}_sk = c.{{ model_name }}_sk
    where t.is_current = 1
)
{{"{%"}} endif {{"%}"}}

select
    {{ model_name }}_sk,
    {{ model_name }}_iri,
    _source_system,
    _source_record_id,
    _loaded_at,
{%- for col in columns %}
    {{ col.target_name }},
{%- endfor %}
    _row_hash,
    valid_from,
    valid_to,
    is_current
from {{"{%"}} if is_incremental() {{"%}"}}changed{{"{%"}} else {{"%}"}}source_versions{{"{%"}} endif {{"%}"}}

{{"{%"}} if is_incremental() {{"%}"}}
union all
select
    {{ model_name }}_sk,
    {{ model_name }}_iri,
    _source_system,
    _source_record_id,
    _loaded_at,
{%- for col in columns %}
    {{ col.target_name }},
{%- endfor %}
    _row_hash,
    valid_from,
    valid_to,
    is_current
from closed
{{"{%"}} endif {{"%}"}}
{%- else %}

select
    {{ sk_expression }} as {{ model_name }}_sk,
    {{ iri_expression }} as {{ model_name }}_iri,
    _source_system,
    _source_record_id,
    {{"{{"}} kairos_current_timestamp() {{"}}"}} as _loaded_at,
{%- for col in columns %}
    {{ col.target_name }}{% if not loop.last %},{% endif %}
{%- endfor %}
from unioned
{%- endif %}

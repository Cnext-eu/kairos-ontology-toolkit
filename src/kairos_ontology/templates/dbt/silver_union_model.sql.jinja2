--
-- Combines {{ source_models | length }} per-source models via UNION ALL, then
-- computes surrogate key (SK) and IRI on normalised columns.

{{"{{"}} config(
    materialized='{{ materialization | default("table") }}',
    schema='{{ schema_name }}'
) {{"}}"}}

with unioned as (

{%- for src in source_models %}
    select * from {{"{{"}} ref('{{ src }}') {{"}}"}}
{%- if not loop.last %}
    union all
{%- endif %}
{%- endfor %}

)

select
    {{ sk_expression }} as {{ model_name }}_sk,
    {{ iri_expression }} as {{ model_name }}_iri,
{%- for col in columns %}
    {{ col.target_name }}{% if not loop.last or joins %},{% endif %}
{%- endfor %}
{%- for join in joins %}
{%- if loop.first %}
    {{ join.expression }} as {{ join.target_name }}{% if not loop.last %},{% endif %}
{%- else %}
    {{ join.expression }} as {{ join.target_name }}{% if not loop.last %},{% endif %}
{%- endif %}
{%- endfor %}
from unioned
{%- for join in joins %}
    {{ join.type }} join {{ join.ref }} as {{ join.alias }}
        on {{ join.condition }}
{%- endfor %}

{%- if ontology_metadata and ontology_metadata.generated_at %}
-- Generated at: {{ ontology_metadata.generated_at }}
{%- endif %}
--
-- This staging model performs light transformations per dbt best practices:
--   ✅ Renaming (source columns → snake_case)
--   ✅ Type casting (source types → Spark SQL / warehouse types)
--   ✅ Basic cleaning (TRIM, COALESCE)
--   ❌ No joins, no aggregations

{{"{{"}} config(
    materialized='view'
) {{"}}"}}

with source as (

    select * from {{"{{"}} source('{{ source_name }}', '{{ raw_table_name }}') {{"}}"}}

),

renamed as (

    select
{%- for col in columns %}
        {{ col.expression }} as {{ col.target_name }}{% if not loop.last %},{% endif %}
{%- endfor %}
    from source
{%- if filter_condition %}
    where {{ filter_condition }}
{%- endif %}

)
{%- if dedup_key %}

, deduplicated as (

    select
        *,
        row_number() over (
            partition by {{ dedup_key }}
            order by {{ dedup_order | default('1') }}
        ) as _row_num
    from renamed

)

select * from deduplicated where _row_num = 1
{%- else %}

select * from renamed
{%- endif %}

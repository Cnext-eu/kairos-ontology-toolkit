#
# Kairos Bronze Layer Vocabulary
# Namespace: https://kairos.cnext.eu/bronze#
#
# Describes source system schemas (tables, columns, types) for the bronze
# layer of the medallion architecture. Used by the dbt projector to generate
# staging models from source system metadata.

@prefix kairos-bronze: <https://kairos.cnext.eu/bronze#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<https://kairos.cnext.eu/bronze>
    a owl:Ontology ;
    rdfs:label "Kairos Bronze Layer Vocabulary" ;
    owl:versionInfo "1.0.0" ;
    rdfs:comment "Schema vocabulary for describing source system tables and columns in the bronze layer." .

# ---------------------------------------------------------------------------
# Classes
# ---------------------------------------------------------------------------

kairos-bronze:SourceSystem a owl:Class ;
    rdfs:label "Source System" ;
    rdfs:comment "A source system (e.g. AdminPulse, ERP, CRM) that feeds bronze-layer data." .

kairos-bronze:SourceTable a owl:Class ;
    rdfs:label "Source Table" ;
    rdfs:comment "A table or view in a source system." .

kairos-bronze:SourceColumn a owl:Class ;
    rdfs:label "Source Column" ;
    rdfs:comment "A column in a source system table." .

# ---------------------------------------------------------------------------
# Source System properties
# ---------------------------------------------------------------------------

kairos-bronze:connectionType a owl:DatatypeProperty ;
    rdfs:label "connection type" ;
    rdfs:comment "Connection technology: jdbc, odbc, api, file, lakehouse." ;
    rdfs:domain kairos-bronze:SourceSystem ;
    rdfs:range xsd:string .

kairos-bronze:database a owl:DatatypeProperty ;
    rdfs:label "database" ;
    rdfs:comment "Database or catalog name in the source system." ;
    rdfs:domain kairos-bronze:SourceSystem ;
    rdfs:range xsd:string .

kairos-bronze:schema a owl:DatatypeProperty ;
    rdfs:label "schema" ;
    rdfs:comment "Default schema name (e.g. dbo, public)." ;
    rdfs:domain kairos-bronze:SourceSystem ;
    rdfs:range xsd:string .

kairos-bronze:systemVersion a owl:DatatypeProperty ;
    rdfs:label "system version" ;
    rdfs:comment "Version of the source system software." ;
    rdfs:domain kairos-bronze:SourceSystem ;
    rdfs:range xsd:string .

# ---------------------------------------------------------------------------
# Source Table properties
# ---------------------------------------------------------------------------

kairos-bronze:sourceSystem a owl:ObjectProperty ;
    rdfs:label "source system" ;
    rdfs:comment "The source system this table belongs to." ;
    rdfs:domain kairos-bronze:SourceTable ;
    rdfs:range kairos-bronze:SourceSystem .

kairos-bronze:schemaName a owl:DatatypeProperty ;
    rdfs:label "schema name" ;
    rdfs:comment "Schema containing this table (overrides system default)." ;
    rdfs:domain kairos-bronze:SourceTable ;
    rdfs:range xsd:string .

kairos-bronze:tableName a owl:DatatypeProperty ;
    rdfs:label "table name" ;
    rdfs:comment "Physical table or view name in the source." ;
    rdfs:domain kairos-bronze:SourceTable ;
    rdfs:range xsd:string .

kairos-bronze:tableType a owl:DatatypeProperty ;
    rdfs:label "table type" ;
    rdfs:comment "Type: table, view, synonym, external." ;
    rdfs:domain kairos-bronze:SourceTable ;
    rdfs:range xsd:string .

kairos-bronze:incrementalColumn a owl:DatatypeProperty ;
    rdfs:label "incremental column" ;
    rdfs:comment "Column used for incremental extraction (e.g. ModifiedDate)." ;
    rdfs:domain kairos-bronze:SourceTable ;
    rdfs:range xsd:string .

kairos-bronze:primaryKeyColumns a owl:DatatypeProperty ;
    rdfs:label "primary key columns" ;
    rdfs:comment "Space-separated list of PK column names." ;
    rdfs:domain kairos-bronze:SourceTable ;
    rdfs:range xsd:string .

# ---------------------------------------------------------------------------
# Source Column properties
# ---------------------------------------------------------------------------

kairos-bronze:sourceTable a owl:ObjectProperty ;
    rdfs:label "source table" ;
    rdfs:comment "The table this column belongs to." ;
    rdfs:domain kairos-bronze:SourceColumn ;
    rdfs:range kairos-bronze:SourceTable .

kairos-bronze:columnName a owl:DatatypeProperty ;
    rdfs:label "column name" ;
    rdfs:comment "Physical column name in the source table." ;
    rdfs:domain kairos-bronze:SourceColumn ;
    rdfs:range xsd:string .

kairos-bronze:dataType a owl:DatatypeProperty ;
    rdfs:label "data type" ;
    rdfs:comment "Source system data type (e.g. int, nvarchar(255), datetime2)." ;
    rdfs:domain kairos-bronze:SourceColumn ;
    rdfs:range xsd:string .

kairos-bronze:nullable a owl:DatatypeProperty ;
    rdfs:label "nullable" ;
    rdfs:comment "Whether the column allows NULL values." ;
    rdfs:domain kairos-bronze:SourceColumn ;
    rdfs:range xsd:boolean .

kairos-bronze:isPrimaryKey a owl:DatatypeProperty ;
    rdfs:label "is primary key" ;
    rdfs:comment "Whether this column is part of the source table primary key." ;
    rdfs:domain kairos-bronze:SourceColumn ;
    rdfs:range xsd:boolean .

kairos-bronze:maxLength a owl:DatatypeProperty ;
    rdfs:label "max length" ;
    rdfs:comment "Maximum length for string/binary columns." ;
    rdfs:domain kairos-bronze:SourceColumn ;
    rdfs:range xsd:integer .

kairos-bronze:precision a owl:DatatypeProperty ;
    rdfs:label "precision" ;
    rdfs:comment "Numeric precision." ;
    rdfs:domain kairos-bronze:SourceColumn ;
    rdfs:range xsd:integer .

kairos-bronze:scale a owl:DatatypeProperty ;
    rdfs:label "scale" ;
    rdfs:comment "Numeric scale." ;
    rdfs:domain kairos-bronze:SourceColumn ;
    rdfs:range xsd:integer .

# ---------------------------------------------------------------------------
# JSON Column Support
# ---------------------------------------------------------------------------

kairos-bronze:contentType a owl:DatatypeProperty ;
    rdfs:label "content type" ;
    rdfs:comment "Physical content type of a column. Values: 'scalar' (default, plain value), 'json-array' (JSON array to be expanded), 'json-object' (JSON object to be parsed). When set to a JSON type, the column requires OPENJSON/LATERAL FLATTEN extraction in staging." ;
    rdfs:domain kairos-bronze:SourceColumn ;
    rdfs:range xsd:string .

kairos-bronze:jsonSchema a owl:ObjectProperty ;
    rdfs:label "json schema" ;
    rdfs:comment "Links a JSON-typed column to its schema definition describing extractable fields." ;
    rdfs:domain kairos-bronze:SourceColumn ;
    rdfs:range kairos-bronze:JsonSchema .

kairos-bronze:jsonPath a owl:DatatypeProperty ;
    rdfs:label "json path" ;
    rdfs:comment "JSON path expression to navigate to the data within the column. Default: '$'." ;
    rdfs:domain kairos-bronze:SourceColumn ;
    rdfs:range xsd:string .

kairos-bronze:JsonSchema a owl:Class ;
    rdfs:label "JSON Schema" ;
    rdfs:comment "Describes the structure of JSON content within a column. Defines extractable fields with their names, types, and paths." .

kairos-bronze:JsonField a owl:Class ;
    rdfs:label "JSON Field" ;
    rdfs:comment "A single field within a JSON schema that can be extracted." .

kairos-bronze:jsonField a owl:ObjectProperty ;
    rdfs:label "json field" ;
    rdfs:comment "Links a JsonSchema to its constituent fields." ;
    rdfs:domain kairos-bronze:JsonSchema ;
    rdfs:range kairos-bronze:JsonField .

kairos-bronze:fieldName a owl:DatatypeProperty ;
    rdfs:label "field name" ;
    rdfs:comment "Name of the JSON field (used as output column name)." ;
    rdfs:domain kairos-bronze:JsonField ;
    rdfs:range xsd:string .

kairos-bronze:fieldType a owl:DatatypeProperty ;
    rdfs:label "field type" ;
    rdfs:comment "Target SQL type for this field. Note: JSON extraction always uses VARCHAR; this type is used for TRY_CAST in silver." ;
    rdfs:domain kairos-bronze:JsonField ;
    rdfs:range xsd:string .

kairos-bronze:fieldPath a owl:DatatypeProperty ;
    rdfs:label "field path" ;
    rdfs:comment "JSON path within the element to extract this field (e.g. '$.name', '$.address.city')." ;
    rdfs:domain kairos-bronze:JsonField ;
    rdfs:range xsd:string .

kairos-bronze:fieldNullable a owl:DatatypeProperty ;
    rdfs:label "field nullable" ;
    rdfs:comment "Whether this JSON field can be null/missing." ;
    rdfs:domain kairos-bronze:JsonField ;
    rdfs:range xsd:boolean .

kairos-bronze:fieldMaxLength a owl:DatatypeProperty ;
    rdfs:label "field max length" ;
    rdfs:comment "Maximum VARCHAR length for extraction. Default: 255." ;
    rdfs:domain kairos-bronze:JsonField ;
    rdfs:range xsd:integer .

# ---------------------------------------------------------------------------
# Discriminator Column Support
# ---------------------------------------------------------------------------

kairos-bronze:discriminatorColumn a owl:ObjectProperty ;
    rdfs:label "discriminator column" ;
    rdfs:comment "Links a source table to its type discriminator column. Used when one table stores multiple entity types distinguished by a column value." ;
    rdfs:domain kairos-bronze:SourceTable ;
    rdfs:range kairos-bronze:SourceColumn .

kairos-bronze:DiscriminatorValue a owl:Class ;
    rdfs:label "Discriminator Value" ;
    rdfs:comment "A known value of a discriminator column with its human-readable label and semantic meaning." .

kairos-bronze:discriminatorValue a owl:ObjectProperty ;
    rdfs:label "discriminator value" ;
    rdfs:comment "Links a source table to its known discriminator values." ;
    rdfs:domain kairos-bronze:SourceTable ;
    rdfs:range kairos-bronze:DiscriminatorValue .

kairos-bronze:discriminatorCode a owl:DatatypeProperty ;
    rdfs:label "discriminator code" ;
    rdfs:comment "The raw code/value stored in the discriminator column." ;
    rdfs:domain kairos-bronze:DiscriminatorValue ;
    rdfs:range xsd:string .

kairos-bronze:discriminatorLabel a owl:DatatypeProperty ;
    rdfs:label "discriminator label" ;
    rdfs:comment "Human-readable label for this discriminator value." ;
    rdfs:domain kairos-bronze:DiscriminatorValue ;
    rdfs:range xsd:string .

# ---------------------------------------------------------------------------
# Enumeration Support
# ---------------------------------------------------------------------------

kairos-bronze:Enumeration a owl:Class ;
    rdfs:label "Enumeration" ;
    rdfs:comment "A reusable set of coded values (enum) with human-readable labels. Can be shared across multiple columns." .

kairos-bronze:EnumValue a owl:Class ;
    rdfs:label "Enum Value" ;
    rdfs:comment "A single code-label pair within an enumeration." .

kairos-bronze:enumeration a owl:ObjectProperty ;
    rdfs:label "enumeration" ;
    rdfs:comment "Links a source column to its enumeration definition." ;
    rdfs:domain kairos-bronze:SourceColumn ;
    rdfs:range kairos-bronze:Enumeration .

kairos-bronze:enumValue a owl:ObjectProperty ;
    rdfs:label "enum value" ;
    rdfs:comment "Links an enumeration to its constituent values." ;
    rdfs:domain kairos-bronze:Enumeration ;
    rdfs:range kairos-bronze:EnumValue .

kairos-bronze:enumCode a owl:DatatypeProperty ;
    rdfs:label "enum code" ;
    rdfs:comment "The raw code stored in the source column." ;
    rdfs:domain kairos-bronze:EnumValue ;
    rdfs:range xsd:string .

kairos-bronze:enumLabel a owl:DatatypeProperty ;
    rdfs:label "enum label" ;
    rdfs:comment "Human-readable label for this enum code." ;
    rdfs:domain kairos-bronze:EnumValue ;
    rdfs:range xsd:string .

kairos-bronze:enumDescription a owl:DatatypeProperty ;
    rdfs:label "enum description" ;
    rdfs:comment "Optional longer description of what this enum value means." ;
    rdfs:domain kairos-bronze:EnumValue ;
    rdfs:range xsd:string .

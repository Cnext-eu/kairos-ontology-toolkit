# Kairos Ontology Toolkit — AI Provider Configuration
# Copy this file as .env and fill in the values for your environment.
# Do NOT commit .env to source control.

# ---------------------------------------------------------------------------
# AI Provider Selection
# ---------------------------------------------------------------------------
# Supported values: github, azure
# Default: github (if GITHUB_TOKEN is set)
# KAIROS_AI_PROVIDER=github

# ---------------------------------------------------------------------------
# GitHub Models (default)
# ---------------------------------------------------------------------------
# Uses GitHub's inference API at https://models.inference.ai.azure.com
# Requires a GitHub PAT with Models API access.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Azure AI Foundry
# ---------------------------------------------------------------------------
# Uses your Azure AI Foundry deployment endpoint.
# Set both AZURE_AI_ENDPOINT and AZURE_AI_KEY, or configure managed identity.
# AZURE_AI_ENDPOINT=https://your-project.services.ai.azure.com/models
# AZURE_AI_KEY=your-api-key-here

# For managed identity (no key needed):
# Install: pip install kairos-ontology-toolkit[azure]
# Then just set AZURE_AI_ENDPOINT — DefaultAzureCredential handles auth.

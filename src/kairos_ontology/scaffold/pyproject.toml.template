[project]
name = "{repo_name}"
version = "0.1.0"
description = "Kairos ontology hub — {description}"
requires-python = ">=3.12"
dependencies = [
    "kairos-ontology-toolkit @ https://github.com/Cnext-eu/kairos-ontology-toolkit/releases/download/{toolkit_ref}/kairos_ontology_toolkit-{toolkit_version}-py3-none-any.whl",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0",
]

[tool.kairos]
# Channel controls which toolkit version is installed on `kairos-ontology update --upgrade`.
#   "stable"  — latest GA release (default)
#   "preview" — latest pre-release (rc/beta/alpha) for testing new features
#   "v2.16.0" — explicit pinned version
channel = "stable"

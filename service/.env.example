# Kairos Ontology Service — Environment Configuration
# Copy to .env and fill in values.

# GitHub App credentials
KAIROS_GITHUB_APP_ID=
KAIROS_GITHUB_APP_PRIVATE_KEY=
KAIROS_GITHUB_INSTALLATION_ID=

# Target ontology repository
KAIROS_GITHUB_REPO_OWNER=Cnext-eu
KAIROS_GITHUB_REPO_NAME=
KAIROS_GITHUB_DEFAULT_BRANCH=main
KAIROS_GITHUB_ONTOLOGIES_PATH=ontologies

# CORS origins (comma-separated)
KAIROS_ALLOWED_ORIGINS=http://localhost:3000
